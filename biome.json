{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!dist",
			"!docs/design",
			"!src/styles/app.css",
			"!src/routeTree.gen.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	}
}
